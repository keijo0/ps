set $mod Mod4
set $alt Mod1
set $left j
set $down i
set $up u
set $right k
output * bg /m/git/wall2/wall.jpg fill

output DP-3 mode 2560x1440@164.999Hz adaptive_sync off render_bit_depth 10 max_render_time off power on scale 1 scale_filter smart

font pango:Quicksand Medium 10
workspace_layout default
default_orientation horizontal
gaps outer 10
gaps inner 10
default_floating_border pixel
#hide_edge_borders smart
smart_gaps on
exec_always gtkfix
input "1189:32769:BenQ_ZOWIE_BenQ_ZOWIE_Gaming_Mouse" accel_profile flat

    bindsym $mod+Return exec alacritty
    bindsym $mod+q kill
    bindsym $mod+x exec thunderbird-bin
    bindsym $mod+p exec dmenu_run
    bindsym $mod+c exec manpdf
    bindsym $mod+m exec firefox
    bindsym $mod+b exec pcmanfm
    bindsym $mod+v exec pavucontrol
    bindsym $mod+a exec keepassxc
    bindsym $mod+s exec 'grim -g "$(slurp)" - | wl-copy'

    floating_modifier $mod normal
    bindsym $mod+Shift+r reload
    bindsym $mod+Shift+e exec killall sway
    bindsym $mod+$left focus left
    bindsym $mod+$down focus down
    bindsym $mod+$up focus up
    bindsym $mod+$right focus right
    bindsym $mod+Shift+$left move left
    bindsym $mod+Shift+$down move down
    bindsym $mod+Shift+$up move up
    bindsym $mod+Shift+$right move right
#
# Workspaces:
#
    # Switch to workspace
    bindsym $mod+1 workspace number 1
    bindsym $mod+2 workspace number 2
    bindsym $mod+3 workspace number 3
    bindsym $mod+4 workspace number 4
    bindsym $mod+5 workspace number 5
    bindsym $mod+6 workspace number 6
    bindsym $mod+7 workspace number 7
    bindsym $mod+8 workspace number 8
    bindsym $mod+9 workspace number 9
    bindsym $mod+0 workspace number 10
    # Move focused container to workspace
    bindsym $mod+Shift+1 move container to workspace number 1
    bindsym $mod+Shift+2 move container to workspace number 2
    bindsym $mod+Shift+3 move container to workspace number 3
    bindsym $mod+Shift+4 move container to workspace number 4
    bindsym $mod+Shift+5 move container to workspace number 5
    bindsym $mod+Shift+6 move container to workspace number 6
    bindsym $mod+Shift+7 move container to workspace number 7
    bindsym $mod+Shift+8 move container to workspace number 8
    bindsym $mod+Shift+9 move container to workspace number 9
    bindsym $mod+Shift+0 move container to workspace number 10
    bindsym $alt+h splith
    bindsym $alt+v splitv
    bindsym $mod+f1 layout stacking
    bindsym $mod+f2 layout tabbed
    bindsym $mod+f3 layout toggle split
    bindsym $mod+f fullscreen
    bindsym $mod+Shift+space floating toggle

mode "resize" {
    bindsym $left resize shrink width 15px
    bindsym $down resize grow height 15px
    bindsym $up resize shrink height 15px
    bindsym $right resize grow width 15px
    bindsym Left resize shrink width 15px
    bindsym Down resize grow height 15px
    bindsym Up resize shrink height 15px
    bindsym Right resize grow width 15px
    bindsym Return mode "default"
    bindsym Escape mode "default"
}
bindsym $mod+tab workspace back_and_forth
######$$$##### who the fuck uses a bar anymore
bar {
    position top
    swaybar_command waybar

    colors {
        statusline #beaa9b
        background #323232
        inactive_workspace #32323200 #32323200 #5c5c5c
    }
}

include /etc/sway/config.d/*

#volume shit
bindsym XF86AudioRaiseVolume exec volume up
bindsym XF86AudioLowerVolume exec volume down 
bindsym XF86AudioMute exec volume mute
bindsym XF86AudioMicMute exec volume mic

mouse_warping none
focus_wrapping yes

exec_always swayidle -w \
	timeout 900 'swaylock -f -c 000000' \
  	timeout 900 'swaymsg "output * dpms off"' \
  	resume 'swaymsg "output * dpms on"' \
  	before-sleep 'swaylock' \


#for_window [class="[.]*"] floating enable

for_window [app_id=".*"] border normal 1
for_window [class="[.]*"] border normal 1
#for_window [class="[.]*"] border none
#for_window [app_id=".*"] border none

#exec_always startnginx

input type:keyboard {
	xkb_layout "us, fi"
	xkb_options "grp:alt_space_toggle"
}

for_window [class=".*"] inhibit_idle fullscreen
for_window [app_id=".*"] inhibit_idle fullscreen
for_window [class="steam_app.*"] inhibit_idle fullscreen; floating disable; border none; move container to workspace number 10
for_window [class="Steam"] floating disable; max_render_time off; move container to workspace number 10
for_window [title="Kodi"] move container to workspace number 8
for_window [title="Thunderbird"] floating disable; move container to workspace number 9
for_window [title="PCSX2"] floating enable
for_window [class="firefox"] border none
for_window [class="feh"] floating enable
for_window [class="pcmanfm"] floating enable
for_window [app_id="nextcloud"] move container to workspace number 2
for_window [app_id="keepassxc"] move container to workspace number 2




client.focused          "#beaa9b" "#010101"      "#beaa9b"   "#010101"	   "#beaa9b"
client.focused_inactive "#23242a" "#010101" 	 "#666666"   "#010101"     "#000000"
client.unfocused        "#000000" "#010101"      "#666666"   "#010101"     "#000000"
client.urgent		"#000000" "#010101"      "#666666"   "#010101"     "#000000"	
client.placeholder	"#000000" "#010101"      "#666666"   "#010101"     "#000000"
client.background $br

titlebar_padding 4 4
title_align right
for_window [app_id=".*"] floating enable
for_window [app_id="Alacritty"] floating enable
for_window [class="pcmanfm"] floating enable
for_window [app_id="firefox"] border none
